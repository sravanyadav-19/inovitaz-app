# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=inovitaz_db

# Auth
JWT_SECRET=replace_with_64_character_random_secret
DOWNLOAD_SECRET=replace_with_64_character_random_secret

# Razorpay
# Leave empty in development to use mock mode.
# Required in production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (SMTP)
# Leave empty in development — emails will be logged to console instead.
# Required in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Inovitaz" <noreply@inovitaz.com>